<Window x:Class="FMOptimization.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FMOptimization.ViewModels"
        xmlns:models="clr-namespace:FMOptimization.Models"
        mc:Ignorable="d"
        Title="FM Optimization"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="500"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" GlassFrameThickness="0" UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <DataTemplate x:Key="CategoryTemplate" DataType="{x:Type vm:CategoryItem}">
            <Border Height="28" Padding="0" x:Name="CatBorder"
                    Background="Transparent" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  CommandParameter="{Binding Name}"/>
                </Border.InputBindings>
                <Grid>
                    <Rectangle Width="2" Height="20" HorizontalAlignment="Left"
                               Fill="{StaticResource AmberPrimaryBrush}"
                               Opacity="0" x:Name="CatAccent"/>
                    <Grid Margin="10,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="6,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="CatBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                    <Setter TargetName="CatAccent" Property="Opacity" Value="1"/>
                    <Setter TargetName="CatAccent" Property="Fill" Value="{StaticResource AmberPrimaryBrush}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ScriptCardTemplate" DataType="{x:Type models:ScriptModel}">
            <Border Width="320" Margin="4"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    x:Name="CardBorder"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.95" To="1" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.95" To="1" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.02" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.02" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Accent bar -->
                    <Rectangle Grid.Column="0" Width="2" RadiusX="1" RadiusY="1"
                               Fill="{Binding Tipo, Converter={StaticResource FileTypeToColor}}"/>
                    <!-- Content -->
                    <Grid Grid.Column="1" Margin="12,8,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Nome}" FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="NoWrap"/>
                        <TextBlock Grid.Row="1" Text="{Binding Descricao}" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Star -->
                            <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.ToggleFavoritoCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding IsFavorito, Converter={StaticResource BoolToStar}}"
                                           FontSize="14"
                                           Foreground="{StaticResource AmberPrimaryBrush}"/>
                            </Button>
                            <!-- Admin badge -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding Admin, Converter={StaticResource AdminToVisibility}}"
                                    Padding="5,1,5,1" Margin="4,0,0,0"
                                    BorderBrush="{StaticResource AmberPrimaryBrush}"
                                    BorderThickness="1" CornerRadius="4">
                                <TextBlock Text="ADMIN" FontSize="8" FontWeight="Bold"
                                           Foreground="{StaticResource AmberPrimaryBrush}"/>
                            </Border>
                            <!-- Category -->
                            <TextBlock Grid.Column="2" Text="{Binding Categoria}" FontSize="9"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="6,0,0,0"/>
                            <!-- Type badge -->
                            <Border Grid.Column="4" Padding="5,1,5,1"
                                    BorderBrush="{Binding Tipo, Converter={StaticResource FileTypeToColor}}"
                                    BorderThickness="1" CornerRadius="4"
                                    Opacity="0.6">
                                <TextBlock Text="{Binding TipoLabel}" FontSize="8" FontWeight="Bold"
                                           Foreground="{Binding Tipo, Converter={StaticResource FileTypeToColor}}"/>
                            </Border>
                        </Grid>
                    </Grid>
                    <!-- Actions column -->
                    <StackPanel Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Top">
                        <Button Content="Executar" Height="28" MinWidth="70" Margin="0,0,0,4"
                                Background="{StaticResource GreenRunBrush}"
                                Foreground="#0d0d1a" FontSize="10" FontWeight="Bold"
                                Cursor="Hand" BorderThickness="0"
                                Command="{Binding DataContext.ExecuteScriptCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="Detalhes" Height="24" MinWidth="70" Margin="0,0,0,2"
                                Background="Transparent"
                                Foreground="{StaticResource CyanAccentBrush}"
                                FontSize="9" Cursor="Hand"
                                BorderBrush="{StaticResource CyanAccentBrush}"
                                BorderThickness="1"
                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="{StaticResource BgPrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{StaticResource BgSidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="0,16,0,4">
                <TextBlock Text="FM" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource AmberPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="OPTIMIZATION" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource CyanAccentBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <Rectangle Height="1" Fill="{StaticResource BorderDefaultBrush}" Margin="16,0"/>
            </StackPanel>
            <!-- Category list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}"
                              x:Name="CategoryList"
                              ItemTemplate="{StaticResource CategoryTemplate}">
                </ItemsControl>
            </ScrollViewer>
            <!-- Manage categories -->
            <Button Grid.Row="2" Height="32" Cursor="Hand"
                    Background="Transparent" BorderThickness="0"
                    Command="{Binding ManageCategoriesCommand}">
                <TextBlock Text="Gerenciar Categorias" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </Button>
        </Grid>
        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BgSidebarBrush}"
                      HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>
        <!-- Content area -->
        <Grid Grid.Column="2" Background="{StaticResource BgPrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Top bar -->
            <Border Grid.Row="0" Height="44" Background="{StaticResource BgSidebarBrush}"
                    Padding="16,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedCategory}" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Margin="8,0,0,0" Padding="8,1,8,1" CornerRadius="10"
                                Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1">
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}">
                                <Run Text="{Binding FilteredScripts.Count, Mode=OneWay}"/>
                                <Run Text=" scripts"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <!-- Search -->
                    <Border Grid.Column="1" HorizontalAlignment="Right" Width="200"
                            Background="{StaticResource BgCardBrush}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1" Margin="0,6,0,6">
                        <TextBox x:Name="SearchBox" FontSize="12" CaretBrush="{StaticResource TextPrimaryBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="8,0,8,0" VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderThickness="0" CornerRadius="6">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                </Grid>
            </Border>
            <!-- Cards grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="8,8,8,0">
                <ItemsControl ItemsSource="{Binding FilteredScripts}"
                              ItemTemplate="{StaticResource ScriptCardTemplate}"
                              x:Name="CardsGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                       ItemWidth="328"
                                       Margin="-4,0,0,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
            <!-- Log panel -->
            <Border Grid.Row="2" Background="{StaticResource BgPrimaryBrush}"
                    x:Name="LogPanel"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Log header -->
                    <Border Grid.Row="0" Height="26" Background="{StaticResource BgSidebarBrush}"
                            Padding="14,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="LOG" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Copiar" Style="{StaticResource GhostButton}"
                                        FontSize="10" Foreground="{StaticResource CyanAccentBrush}"
                                        Command="{Binding CopyLogCommand}"/>
                                <Button Content="Limpar" Style="{StaticResource GhostButton}"
                                        FontSize="10"
                                        Command="{Binding ClearLogCommand}"/>
                                <Button Content="&#x25B2;" Style="{StaticResource GhostButton}"
                                        FontSize="8" x:Name="LogToggleBtn"
                                        Command="{Binding ToggleLogCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Log messages -->
                    <ScrollViewer Grid.Row="1" x:Name="LogScrollView"
                                  MaxHeight="120" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:LogEntry}">
                                    <TextBlock Text="{Binding Message}" FontSize="11"
                                               FontFamily="Consolas"
                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"
                                               TextWrapping="Wrap" Padding="14,0,14,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
