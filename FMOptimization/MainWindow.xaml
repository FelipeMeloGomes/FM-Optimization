<Window x:Class="FMOptimization.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FMOptimization.ViewModels"
        xmlns:conv="clr-namespace:FMOptimization.Converters"
        xmlns:controls="clr-namespace:FMOptimization.Controls"
        mc:Ignorable="d"
        Title="FM Optimization"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="500"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen"
        x:Name="ThisWindow"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <conv:IndexToDelayConverter x:Key="IndexToDelay"/>
    </Window.Resources>

    <Grid Background="{StaticResource BgPrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <controls:SidebarControl Grid.Column="0"
            Categories="{Binding Categories}"
            SelectedCategory="{Binding SelectedCategory}"
            SelectCategoryCommand="{Binding SelectCategoryCommand}"
            ManageCategoriesCommand="{Binding ManageCategoriesCommand}"/>

        <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                      HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

        <Grid Grid.Column="2" Background="{StaticResource BgPrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="3" Fill="{StaticResource BgGridTexture}" Opacity="0.15"/>

            <controls:CircuitBackground Grid.RowSpan="3"/>

            <controls:TopBarControl Grid.Row="0" x:Name="TopBar"
                SelectedCategory="{Binding SelectedCategory}"
                ScriptCount="{Binding FilteredScripts.Count}"
                SearchText="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="8,8,8,0"
                          Background="Transparent">
                <ItemsControl ItemsSource="{Binding FilteredScripts}"
                              x:Name="CardsGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                       ItemWidth="332"
                                       Margin="-6,0,0,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:ScriptCardControl
                                Script="{Binding}"
                                ToggleFavoritoCommand="{Binding DataContext.ToggleFavoritoCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                ShowDetailsCommand="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                ExecuteScriptCommand="{Binding DataContext.ExecuteScriptCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <controls:LogPanelControl Grid.Row="2"
                LogEntries="{Binding LogEntries}"
                LogExpanded="{Binding LogExpanded}"
                CopyLogCommand="{Binding CopyLogCommand}"
                ClearLogCommand="{Binding ClearLogCommand}"
                ToggleLogCommand="{Binding ToggleLogCommand}"/>
        </Grid>
    </Grid>
</Window>
