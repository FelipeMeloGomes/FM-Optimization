<Application x:Class="FMOptimization.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FMOptimization.ViewModels"
             xmlns:conv="clr-namespace:FMOptimization.Converters"
             xmlns:local="clr-namespace:FMOptimization">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Font Families -->
            <FontFamily x:Key="FontUI">pack://application:,,,/Assets/Fonts/#Rajdhani</FontFamily>
            <FontFamily x:Key="FontUIBold">pack://application:,,,/Assets/Fonts/#Rajdhani</FontFamily>
            <FontFamily x:Key="FontMono">pack://application:,,,/Assets/Fonts/#JetBrains Mono</FontFamily>
            <FontFamily x:Key="FontMonoBold">pack://application:,,,/Assets/Fonts/#JetBrains Mono</FontFamily>
            <FontFamily x:Key="FontLogo">pack://application:,,,/Assets/Fonts/#Audiowide</FontFamily>

            <!-- Colors -->
            <Color x:Key="BgDeep">#07071a</Color>
            <Color x:Key="BgPrimary">#0a0a1e</Color>
            <Color x:Key="BgSurface">#0d0d24</Color>
            <Color x:Key="BgSidebar">#0f0f28</Color>
            <Color x:Key="BgElevated">#14143a</Color>
            <Color x:Key="BgCard">#11112a</Color>
            <Color x:Key="BgLog">#080818</Color>
            <Color x:Key="TextPrimary">#e8eaf0</Color>
            <Color x:Key="TextMuted">#6b7194</Color>
            <Color x:Key="TextDim">#4a5080</Color>
            <Color x:Key="BorderDefault">#1e1e4a</Color>
            <Color x:Key="BorderHover">#3a3a7a</Color>
            <Color x:Key="BorderGlow">#0066ff</Color>
            <Color x:Key="NeonBlue">#0044ff</Color>
            <Color x:Key="NeonBlueDark">#0022aa</Color>
            <Color x:Key="NeonBlueLight">#0066ff</Color>
            <Color x:Key="NeonBlueMid">#0033cc</Color>
            <Color x:Key="GreenRun">#00e676</Color>
            <Color x:Key="GreenDark">#00c853</Color>
            <Color x:Key="RedError">#ff1744</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
            <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}"/>
            <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}"/>
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}"/>
            <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
            <SolidColorBrush x:Key="BgLogBrush" Color="{StaticResource BgLog}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
            <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>
            <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}"/>
            <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHover}"/>
            <SolidColorBrush x:Key="BorderGlowBrush" Color="{StaticResource BorderGlow}"/>
            <SolidColorBrush x:Key="NeonBlueBrush" Color="{StaticResource NeonBlue}"/>
            <SolidColorBrush x:Key="NeonBlueLightBrush" Color="{StaticResource NeonBlueLight}"/>
            <SolidColorBrush x:Key="NeonBlueDarkBrush" Color="{StaticResource NeonBlueDark}"/>
            <SolidColorBrush x:Key="GreenRunBrush" Color="{StaticResource GreenRun}"/>
            <SolidColorBrush x:Key="RedErrorBrush" Color="{StaticResource RedError}"/>

            <!-- Gradient Brushes -->
            <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#14143a" Offset="0"/>
                <GradientStop Color="#0a0a1e" Offset="0.6"/>
                <GradientStop Color="#07071a" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="NeonGradient" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="{StaticResource NeonBlue}" Offset="0"/>
                <GradientStop Color="{StaticResource NeonBlueDark}" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="NeonGradientLight" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="{StaticResource NeonBlueLight}" Offset="0"/>
                <GradientStop Color="{StaticResource NeonBlueMid}" Offset="1"/>
            </LinearGradientBrush>

            <!-- Background Texture (Subtle Grid) -->
            <DrawingBrush x:Key="BgGridTexture" TileMode="Tile"
                          Viewport="0,0,32,32" ViewportUnits="Absolute"
                          Viewbox="0,0,32,32" ViewboxUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Geometry="M0,0 L32,0 M0,0 L0,32">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#1a1a3a" Thickness="0.5"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Geometry="M32,0 L32,32 M0,32 L32,32">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#1e1e4a" Thickness="0.5">
                                    <Pen.DashStyle>
                                        <DashStyle Dashes="2,2"/>
                                    </Pen.DashStyle>
                                </Pen>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- Scan-line overlay brush -->
            <DrawingBrush x:Key="ScanLineTexture" TileMode="Tile"
                          Viewport="0,0,1,4" ViewportUnits="Absolute"
                          Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                <DrawingBrush.Drawing>
                    <GeometryDrawing Geometry="M0,0 L1,0 M0,2 L1,2">
                        <GeometryDrawing.Pen>
                            <Pen Thickness="1">
                                <Pen.Brush>
                                    <SolidColorBrush Color="#0a0a1e" Opacity="0.15"/>
                                </Pen.Brush>
                            </Pen>
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- Drop Shadow Effects -->
            <DropShadowEffect x:Key="CardShadow" ShadowDepth="4" BlurRadius="12"
                              Color="#000000" Opacity="0.4" Direction="270"/>
            <DropShadowEffect x:Key="GlowNeon" ShadowDepth="0" BlurRadius="16"
                              Color="{StaticResource NeonBlue}" Opacity="0.3"/>
            <DropShadowEffect x:Key="GlowNeonLight" ShadowDepth="0" BlurRadius="16"
                              Color="{StaticResource NeonBlueLight}" Opacity="0.3"/>
            <DropShadowEffect x:Key="GlowGreen" ShadowDepth="0" BlurRadius="12"
                              Color="{StaticResource GreenRun}" Opacity="0.2"/>

            <!-- Converters -->
            <conv:IconConverter x:Key="IconConverter"/>
            <conv:IconToColorConverter x:Key="IconToColor"/>
            <conv:FileTypeToColorConverter x:Key="FileTypeToColor"/>
            <conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>
            <conv:BoolToStarConverter x:Key="BoolToStar"/>
            <conv:AdminToVisibilityConverter x:Key="AdminToVisibility"/>
            <conv:LogLevelToColorConverter x:Key="LogLevelToColor"/>

            <!-- Global Styles -->
            <Style TargetType="Window" x:Key="DarkWindowStyle">
                <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style x:Key="TextMono" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style x:Key="SidebarItemStyle" TargetType="Border">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Margin" Value="8,1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1a1a3e"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            </Style>

            <Style TargetType="TextBox" x:Key="DarkTextBox">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="CaretBrush" Value="{StaticResource NeonBlueLightBrush}"/>
            </Style>

            <Style TargetType="Button" x:Key="GhostButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="AccentButton">
                <Setter Property="Background" Value="{StaticResource NeonBlueBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUIBold}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    BorderThickness="0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="OutlineButton">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource NeonBlueLightBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource NeonBlueLightBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          SnapsToDevicePixels="True"/>
                                        <Path Grid.Column="1"
                                              x:Name="Arrow"
                                              Data="M0,0 L6,0 L3,4 Z"
                                              Fill="{StaticResource TextMutedBrush}"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ToggleButton
                                    Grid.Row="0"
                                    x:Name="ToggleButton"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    ClickMode="Press"
                                    Focusable="False"
                                    IsTabStop="False">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       Placement="Bottom">
                                    <Grid MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="{StaticResource BgElevatedBrush}"
                                                BorderBrush="{StaticResource BorderHoverBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"/>
                                        <ScrollViewer Background="Transparent"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      Padding="2">
                                            <ItemsPresenter SnapsToDevicePixels="True"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource NeonBlueLightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True"
                                    CornerRadius="4">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BorderDefaultBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource NeonBlueLightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="SmallIconButton">
                <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True"
                                    Padding="6,2">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
