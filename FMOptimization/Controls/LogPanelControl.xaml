<UserControl x:Class="FMOptimization.Controls.LogPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FMOptimization.ViewModels"
             xmlns:models="clr-namespace:FMOptimization.Models"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="800">
    <Border Background="{StaticResource BgLogBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,1,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="2" Fill="{StaticResource ScanLineTexture}" IsHitTestVisible="False"/>

            <Border Grid.Row="0" Height="28"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6"
                                 Fill="{StaticResource GreenRunBrush}" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                                  Color="{StaticResource GreenRun}" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="TERMINAL" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource GreenRunBrush}"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource FontUIBold}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Copiar" Style="{StaticResource GhostButton}"
                                FontSize="10" Foreground="{StaticResource NeonBlueLightBrush}"
                                Margin="0,0,6,0"
                                Command="{Binding CopyLogCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                        <Button Content="Limpar" Style="{StaticResource GhostButton}"
                                FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                Margin="0,0,6,0"
                                Command="{Binding ClearLogCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                        <Button Content="▲" Style="{StaticResource GhostButton}"
                                FontSize="8" x:Name="LogToggleBtn"
                                Foreground="{StaticResource TextMutedBrush}"
                                Command="{Binding ToggleLogCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="LogScrollView"
                          MaxHeight="160" VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <Grid>
                    <ItemsControl ItemsSource="{Binding LogEntries, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  x:Name="LogItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:LogEntry}">
                                <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Padding="14,0,14,0">
                                    <Run Text="[" Foreground="{StaticResource GreenRunBrush}"/>
                                    <Run Text="{Binding Timestamp}" Foreground="{StaticResource GreenRunBrush}"/>
                                    <Run Text="]" Foreground="{StaticResource GreenRunBrush}"/>
                                    <Run Text=" " Foreground="{StaticResource TextDimBrush}"/>
                                    <Run Text="{Binding Message, Mode=OneWay}"
                                         Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="|" FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{StaticResource GreenRunBrush}"
                               Margin="14,0,0,0"
                               Opacity="1"
                               x:Name="LogCursor">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="1" To="0" Duration="0:0:0.5"
                                            AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
