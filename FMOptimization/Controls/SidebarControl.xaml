<UserControl x:Class="FMOptimization.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FMOptimization.ViewModels"
             xmlns:models="clr-namespace:FMOptimization.Models"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="200">
    <UserControl.Resources>
        <DataTemplate x:Key="CategoryTemplate" DataType="{x:Type models:CategoryItem}">
            <Border Height="36" Margin="8,1,8,1" Padding="0"
                    Background="Transparent" Cursor="Hand"
                    CornerRadius="6"
                    x:Name="CatBorder">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding Name}"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a1a3e"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Rectangle Width="3" Height="20" HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5"
                               Fill="{StaticResource NeonBlueLightBrush}"
                               Opacity="0" Margin="0,0,0,0" x:Name="CatAccent">
                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                              Color="{StaticResource NeonBlueLight}" Opacity="0.5"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Border x:Name="ActiveFill" CornerRadius="6" Opacity="0"
                            Background="{StaticResource NeonBlueBrush}"
                            Margin="0,0,0,0"/>
                    <Grid Margin="20,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="16" Height="16" Stretch="Uniform"
                              Fill="{StaticResource TextMutedBrush}" Margin="0,0,10,0"
                              Data="{Binding Name, Converter={StaticResource IconConverter}}"
                              VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CatAccent"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.2"/>
                                <ColorAnimation Storyboard.TargetName="CatAccent"
                                                Storyboard.TargetProperty="Fill.(SolidColorBrush.Color)"
                                                To="{StaticResource NeonBlueLight}" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="ActiveFill"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.12" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CatAccent"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="ActiveFill"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource SidebarGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="52" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1" Margin="0,0,0,0">
            <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="FM" FontSize="24" FontWeight="Bold"
                           FontFamily="{StaticResource FontLogo}"
                           Foreground="{StaticResource NeonBlueBrush}"
                           Height="26"/>
                <TextBlock Text="OPTIMIZATION" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource NeonBlueLightBrush}"
                           FontFamily="{StaticResource FontUIBold}"
                           Margin="0,-2,0,0"
                           TextOptions.TextRenderingMode="ClearType"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            <ItemsControl ItemsSource="{Binding Categories, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                          ItemTemplate="{StaticResource CategoryTemplate}"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2">
            <Border Height="40" Cursor="Hand"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0" x:Name="AddScriptBtn">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a1a3e"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding AddScriptCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                </Border.InputBindings>
                <Grid Margin="20,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="+" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource NeonBlueBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="Adicionar Script" FontSize="12"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <Border Height="40" Cursor="Hand"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,1,0,0" x:Name="ManageBtn">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a1a3e"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ManageCategoriesCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                </Border.InputBindings>
                <Grid Margin="20,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚙" FontSize="14"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="Gerenciar Categorias" FontSize="12"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
