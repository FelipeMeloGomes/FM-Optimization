<UserControl x:Class="FMOptimization.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="52" d:DesignWidth="800">
    <Border Height="52"
            Background="{StaticResource BgSidebarBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="0,0,16,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,0,1,0" Width="200">
                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="FM" FontSize="24" FontWeight="Bold"
                               FontFamily="{StaticResource FontLogo}"
                               Foreground="{StaticResource NeonBlueBrush}"
                               Height="26"/>
                    <TextBlock Text="OPTIMIZATION" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource NeonBlueLightBrush}"
                               FontFamily="{StaticResource FontUIBold}"
                               Margin="0,-2,0,0"
                               TextOptions.TextRenderingMode="ClearType"/>
                </StackPanel>
            </Border>

            <!-- Category + Count -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="20,0,0,0">
                <TextBlock Text="{Binding SelectedCategory, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="{StaticResource FontUIBold}"
                           VerticalAlignment="Center"/>
                <Border Margin="10,0,0,0" Padding="8,1,8,1" CornerRadius="10"
                        Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}">
                        <Run Text="{Binding ScriptCount, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneWay}"/>
                        <Run Text=" scripts"/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Search -->
            <Border Grid.Column="2" HorizontalAlignment="Right" Width="240"
                    Background="{StaticResource BgCardBrush}"
                    CornerRadius="6"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" Margin="0,8,0,8"
                    x:Name="SearchBorder"
                    MouseDown="SearchBorder_MouseDown">
                <TextBox x:Name="SearchBox" FontSize="14"
                         FontFamily="{StaticResource FontUI}"
                         CaretBrush="{StaticResource NeonBlueLightBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="{StaticResource BgCardBrush}"
                         BorderThickness="0"
                         Padding="12,0,12,0" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
