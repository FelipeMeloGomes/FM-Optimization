<UserControl x:Class="FMOptimization.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="800">
    <Border Height="48"
            Background="{StaticResource BgSidebarBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,0,16,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedCategory, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="{StaticResource FontUIBold}"
                           VerticalAlignment="Center"/>
                <Border Margin="10,0,0,0" Padding="8,1,8,1" CornerRadius="10"
                        Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}">
                        <Run Text="{Binding ScriptCount, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneWay}"/>
                        <Run Text=" scripts"/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" HorizontalAlignment="Right" Width="240"
                    Background="{StaticResource BgCardBrush}"
                    CornerRadius="6"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" Margin="0,6,0,6"
                    x:Name="SearchBorder"
                    MouseDown="SearchBorder_MouseDown">
                <TextBox x:Name="SearchBox" FontSize="12"
                         FontFamily="{StaticResource FontUI}"
                         CaretBrush="{StaticResource NeonBlueLightBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="{StaticResource BgCardBrush}"
                         BorderThickness="0"
                         Padding="12,0,12,0" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
