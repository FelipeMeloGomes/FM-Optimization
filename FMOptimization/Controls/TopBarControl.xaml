<UserControl x:Class="FMOptimization.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="52" d:DesignWidth="800">
    <Border Height="52"
            Background="{StaticResource BgSidebarBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="0,0,16,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,0,1,0" Width="200">
                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="FM" FontSize="24" FontWeight="Bold"
                               FontFamily="{StaticResource FontLogo}"
                               Foreground="{StaticResource NeonBlueBrush}"
                               Height="26"/>
                    <TextBlock Text="OPTIMIZATION" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource NeonBlueLightBrush}"
                               FontFamily="{StaticResource FontUIBold}"
                               Margin="0,-2,0,0"
                               TextOptions.TextRenderingMode="ClearType"/>
                </StackPanel>
            </Border>

            <!-- Category + Count -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="20,0,0,0">
                <TextBlock Text="{Binding SelectedCategory, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="{StaticResource FontUIBold}"
                           VerticalAlignment="Center"/>
                <Border Margin="10,0,0,0" Padding="8,1,8,1" CornerRadius="10"
                        Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}">
                        <Run Text="{Binding ScriptCount, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneWay}"/>
                        <Run Text=" scripts"/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Profile Avatar Button -->
            <Button Grid.Column="2" Width="36" Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0"
                    x:Name="ProfileBtn"
                    Click="ProfileBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="18" Width="36" Height="36"
                                Cursor="Hand">
                            <TextBlock Text="👤" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource NeonBlueDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Profile Popup -->
            <Popup x:Name="ProfilePopup" PlacementTarget="{Binding ElementName=ProfileBtn}"
                   Placement="Bottom" StaysOpen="False"
                   PopupAnimation="Slide"
                   AllowsTransparency="True"
                   HorizontalOffset="-120"
                   Closed="ProfilePopup_Closed">
                <Border Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Width="220"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <!-- Avatar circle -->
                        <Border Width="48" Height="48" CornerRadius="24"
                                Background="{StaticResource NeonBlueDarkBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <TextBlock Text="👤" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Editable name -->
                        <TextBlock Text="Nome de Exibição" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox FontSize="14"
                                 FontFamily="{StaticResource FontUIBold}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="{StaticResource BgCardBrush}"
                                 BorderBrush="{StaticResource BorderDefaultBrush}"
                                 BorderThickness="1"
                                 Padding="8,4"
                                 CaretBrush="{StaticResource NeonBlueLightBrush}"
                                 Text="{Binding Profile.NomeExibicao, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SaveProfileNameCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            </TextBox.InputBindings>
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource NeonBlueBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Readonly info -->
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,12,0,4">Usuário do Windows</TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding Profile.UserName, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>

                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,8,0,4">Computador</TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding Profile.MachineName, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>

                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,8,0,4">Membro desde</TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding Profile.PrimeiroUso, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Search -->
            <Border Grid.Column="3" HorizontalAlignment="Right" Width="240"
                    Background="{StaticResource BgCardBrush}"
                    CornerRadius="6"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" Margin="0,8,0,8"
                    x:Name="SearchBorder"
                    MouseDown="SearchBorder_MouseDown">
                <TextBox x:Name="SearchBox" FontSize="14"
                         FontFamily="{StaticResource FontUI}"
                         CaretBrush="{StaticResource NeonBlueLightBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="{StaticResource BgCardBrush}"
                         BorderThickness="0"
                         Padding="12,0,12,0" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
