<Window x:Class="FMOptimization.DialogManageCategories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Categorias" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUI}"
        MouseDown="Window_MouseDown"
        x:Name="ThisDialog">
    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetProperty="(Window.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.92" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(Window.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.92" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid>
        <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12" Opacity="0.98"/>
        <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1" CornerRadius="12"/>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Gerenciar Categorias" FontSize="18" FontWeight="Bold"
                           FontFamily="{StaticResource FontUIBold}"
                           Foreground="{StaticResource NeonBlueBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                        Style="{StaticResource GhostButton}"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="14"
                        Click="CancelClick"/>
            </Grid>

            <!-- Add category row -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="6"
                        BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                        Background="{StaticResource BgCardBrush}">
                    <TextBox x:Name="TxtNovaCategoria"
                             Background="Transparent"
                             BorderThickness="0" Padding="8,8"
                             FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource NeonBlueLightBrush}"
                             GotFocus="Field_GotFocus" LostFocus="Field_LostFocus"/>
                </Border>
                <Button Grid.Column="1" Content="Adicionar" Margin="8,0,0,0"
                        Height="32" Padding="14,0"
                        Style="{StaticResource AccentButton}"
                        FontSize="12"
                        Click="AddClick"/>
            </Grid>

            <!-- Category list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel x:Name="CatStackPanel"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancelar" Width="100" Height="36" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{StaticResource TextMutedBrush}"
                        BorderThickness="0" FontSize="13"
                        Click="CancelClick"/>
                <Button Content="Salvar" Width="100" Height="36"
                        Style="{StaticResource AccentButton}"
                        FontSize="13"
                        Click="SaveClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
