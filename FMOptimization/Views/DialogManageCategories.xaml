<Window x:Class="FMOptimization.DialogManageCategories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Categorias" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d0d1a"
        Foreground="#eef0f4">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="#8a8fa3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#eef0f4"/>
            <Setter Property="BorderBrush" Value="#2a2a4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Add category row -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="TxtNovaCategoria"/>
            <Button Grid.Column="1" Content="Adicionar" Margin="8,0,0,0"
                    Height="28" Padding="12,0"
                    Background="#ff8c00" Foreground="#0d0d1a" FontWeight="Bold"
                    BorderThickness="0"
                    Click="AddClick"/>
        </Grid>
        <!-- Category list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CatStackPanel"/>
        </ScrollViewer>
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="80" Height="28" Margin="0,0,8,0"
                    Background="Transparent" Foreground="#8a8fa3" BorderThickness="0"
                    Click="CancelClick"/>
            <Button Content="Salvar" Width="80" Height="28"
                    Background="#ff8c00" Foreground="#0d0d1a" FontWeight="Bold"
                    BorderThickness="0"
                    Click="SaveClick"/>
        </StackPanel>
    </Grid>
</Window>
