<Window x:Class="FMOptimization.DialogEditScript"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar Script" Height="360" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d0d1a"
        Foreground="#eef0f4">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="#8a8fa3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#eef0f4"/>
            <Setter Property="BorderBrush" Value="#2a2a4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#eef0f4"/>
            <Setter Property="BorderBrush" Value="#2a2a4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="Nome:"/>
        <TextBox Grid.Row="1" x:Name="TxtNome"/>

        <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Descrição:"/>
        <TextBox Grid.Row="3" x:Name="TxtDescricao" TextWrapping="Wrap" Height="60"/>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="Categoria:"/>
            <ComboBox Grid.Row="1" x:Name="CboCategoria" Margin="0,2,0,8"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtCaminho" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="..." Margin="4,0,0,0" Width="32"
                        Background="#1a1a2e" Foreground="#eef0f4"
                        BorderBrush="#2a2a4a" BorderThickness="1"
                        Click="BrowseClick"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="80" Height="28" Margin="0,0,8,0"
                    Background="Transparent" Foreground="#8a8fa3" BorderThickness="0"
                    Click="CancelClick"/>
            <Button Content="Salvar" Width="80" Height="28"
                    Background="#ff8c00" Foreground="#0d0d1a" FontWeight="Bold"
                    BorderThickness="0"
                    Click="SaveClick"/>
        </StackPanel>
    </Grid>
</Window>
